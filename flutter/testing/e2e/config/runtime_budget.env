# Nightly Android E2E runtime budget thresholds.
# Measured against [e2e-local] duration.patrol_test.

# Soft warning threshold in seconds.
E2E_WARN_RUNTIME_SECONDS=540

# Hard failure threshold in seconds.
E2E_MAX_RUNTIME_SECONDS=900

# Reference baseline in seconds (aggregate full E2E run).
E2E_BASELINE_RUNTIME_SECONDS=421

# Warn/fail when runtime increase versus baseline exceeds these percentages.
E2E_WARN_INCREASE_PCT=20
E2E_FAIL_INCREASE_PCT=40
